generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // This line is required to complete the relationship
  transactions Transaction[]
}

model Transaction {
  id        String   @id @default(uuid())
  amount    Float
  category  String
  note      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
