generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  transactions       Transaction[]
  budgets            Budget[]
  assets             Asset[]
  liabilities        Liability[]
  netWorthSnapshots  NetWorthSnapshot[]
  mutualFundHoldings MutualFundHolding[]
  stockHoldings      StockHolding[]
  insurances         Insurance[]
  goals              Goal[]
}

model Transaction {
  id        String   @id @default(uuid())
  amount    Float
  type      String   // 'income' | 'expense'
  category  String
  merchant  String
  date      String
  note      String?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Budget {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  category  String
  limit     Float
  period    String   @default("monthly")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  name                String
  ticker              String?
  quantity            Float    @default(1.0)
  type                String   // 'Market' | 'Manual'
  currentValueInCents Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Liability {
  id                      String   @id @default(uuid())
  userId                  String
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  loanName                String
  category                String   @default("Other") // e.g., 'Education', 'Home', 'Personal'
  
  totalPrincipalInCents   Int
  emiInCents              Int?     // Optional for informal debts without a fixed EMI
  interestRate            Float    // e.g. 5.5 for 5.5%
  remainingBalanceInCents Int
  
  dueDate                 String?  // Stored as 'YYYY-MM-DD' or simple day string '15'
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model NetWorthSnapshot {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  totalAssetsInCents Int
  totalLiabsInCents  Int
  netWorthInCents    Int
  timestamp          DateTime @default(now())
}

model MutualFundHolding {
  id                   String    @id @default(cuid())
  userId               String
  schemeCode           String
  schemeName           String
  fundHouse            String    @default("")
  category             String    @default("Equity")

  // Lumpsum fields
  units                Float     @default(0)
  avgNAV               Float     @default(0)
  currentNAV           Float     @default(0)
  investedAt           String?   // Date string YYYY-MM-DD

  // SIP fields (null = not a SIP holding)
  isSIP                Boolean   @default(false)
  sipAmount            Float?    // Monthly SIP amount in ₹
  sipDay               Int?      // Day of month (1-28)
  sipStartDate         String?   // YYYY-MM-DD
  totalSipInstallments Int       @default(0)

  navLastUpdated       DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StockHolding {
  id                String    @id @default(cuid())
  userId            String
  ticker            String    // e.g. TCS.NS, AAPL, BTC-USD
  exchange          String    // 'NSE' | 'US' | 'CRYPTO'
  companyName       String
  quantity          Float
  avgBuyPrice       Float     // In ₹
  currentPrice      Float     @default(0) // In ₹
  currency          String    @default("INR") // Original currency before conversion

  priceLastUpdated  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum InsuranceType {
  HEALTH
  TERM_LIFE
  MOTOR
  HOME
}

model Insurance {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type          String   // e.g., 'HEALTH', 'TERM_LIFE', 'MOTOR', 'HOME'
  policyName    String
  provider      String
  
  sumInsured    BigInt   // Coverage amount in cents
  premiumAmount BigInt   // Cost per cycle in cents
  frequency     String   // "Monthly", "Quarterly", "Yearly"
  
  startDate     DateTime
  nextDueDate   DateTime // The system handles this
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Goal {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name          String
  targetAmount  Float
  currentAmount Float    @default(0) 
  targetDate    DateTime?
  icon          String?  @default("🎯")
  color         String?  @default("#6366f1")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}