generator client {
  provider = "prisma-client-js"
  // REMOVE moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  // Ensure no 'url' line is here if you're using prisma.config.ts
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}